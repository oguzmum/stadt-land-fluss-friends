{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Server debuggen",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/tsx",
      "args": ["src/index.ts"],
      "cwd": "${workspaceFolder}/packages/server",
      "sourceMaps": true,
      "resolveSourceMapLocations": [
        "${workspaceFolder}/**",
        "!**/node_modules/**"
      ]
    }
  ]
}
